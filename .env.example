# Optional local configuration for TabRows.
# Copy to .env only if your process manager loads env files.

# HOST=127.0.0.1
# PORT=4310
# TABROWS_DATA_DIR=./data
# TABROWS_DB_PATH=./data/tabrows.sqlite

# Set to 1 when serving behind HTTPS.
# TABROWS_SECURE_COOKIES=1

# Set to 0 after creating intended accounts if open registration is not wanted.
# TABROWS_ALLOW_REGISTRATION=0
