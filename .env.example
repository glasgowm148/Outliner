# Optional local configuration for Outliner.
# Copy to .env only if your process manager loads env files.

# HOST=127.0.0.1
# PORT=4310
# OUTLINER_DATA_DIR=./data
# OUTLINER_DB_PATH=./data/outliner.sqlite

# Set to 1 when serving behind HTTPS.
# OUTLINER_SECURE_COOKIES=1

# Set to 0 after creating intended accounts if open registration is not wanted.
# OUTLINER_ALLOW_REGISTRATION=0
